# Ville suivie
CITY_NAME=Paris
LATITUDE=48.8566
LONGITUDE=2.3522
POLL_INTERVAL_SECONDS=30

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC=weather.raw

# PostgreSQL météo
WEATHER_DB_NAME=weather
WEATHER_DB_USER=weather_user
WEATHER_DB_PASSWORD=change_me_weather
WEATHER_DB_PORT=5433

# Airflow
AIRFLOW_UID=50000
AIRFLOW_DB_NAME=airflow
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=change_me_airflow_db
AIRFLOW_USER=airflow
AIRFLOW_PASSWORD=change_me_airflow_ui

# Grafana
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana
